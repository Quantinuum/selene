    %pi = load double, ptr @pi
    %half_pi = load double, ptr @half_pi
    %minus_half_pi = load double, ptr @minus_half_pi
    %quarter_pi = load double, ptr @quarter_pi
    %minus_quarter_pi = load double, ptr @minus_quarter_pi


    tail call void @setup(i64 %0)

    ; allocate 10 qubits

    %lhs_0 = tail call i64 @___qalloc()
    %lhs_1 = tail call i64 @___qalloc()
    %lhs_2 = tail call i64 @___qalloc()
    %lhs_3 = tail call i64 @___qalloc()
    %rhs_0 = tail call i64 @___qalloc()
    %rhs_1 = tail call i64 @___qalloc()
    %rhs_2 = tail call i64 @___qalloc()
    %rhs_3 = tail call i64 @___qalloc()
    %carry = tail call i64 @___qalloc()
