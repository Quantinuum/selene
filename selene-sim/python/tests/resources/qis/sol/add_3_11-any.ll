    tail call void @___rp(i64 %lhs_0, double %pi, double %zero)
    tail call void @___rp(i64 %lhs_1, double %pi, double %zero)
    ; rhs = 11 = 0b1011
    tail call void @___rp(i64 %rhs_0, double %pi, double %zero)
