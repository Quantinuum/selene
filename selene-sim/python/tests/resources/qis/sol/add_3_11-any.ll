    ; reset them all to |0>

    tail call void @___reset(i64 %lhs_0)
    tail call void @___reset(i64 %lhs_1)
    tail call void @___reset(i64 %lhs_2)
    tail call void @___reset(i64 %lhs_3)
    tail call void @___reset(i64 %rhs_0)
    tail call void @___reset(i64 %rhs_1)
    tail call void @___reset(i64 %rhs_2)
    tail call void @___reset(i64 %rhs_3)
    tail call void @___reset(i64 %carry)
    tail call void @___reset(i64 %ancilla)

