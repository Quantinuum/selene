{
    "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
    "bootstrap-sha": "45211c055979361701b2246e0a2c59b87d846bb2",
    "separate-pull-requests": true,
    "pull-request-title-pattern": "chore: release${component} ${version}",
    "bump-minor-pre-major": true,
    "bump-patch-for-minor-pre-major": true,
    "include-component-in-tag": true,
    "packages": {
        "selene-core": {
            "release-type": "python",
            "package-name": "selene-core",
            "component": "selene-core",
            "draft": false,
            "versioning": "prerelease",
            "prerelease": true,
            "prerelease-type": "alpha",
            "draft-pull-request": true,
            "extra-files": [
                {
                    "type": "toml",
                    "path": "Cargo.toml",
                    "jsonpath": "$.package.version"
                },
                {
                    "type": "toml",
                    "path": "/**/Cargo.lock",
                    "jsonpath": "$.package[?(@.name.value=='selene-core')].version",
                    "glob": true
                },
                {
                    "type": "toml",
                    "path": "/uv.lock",
                    "jsonpath": "$.package[?(@.name.value=='selene-core')].version"
                },
                {
                    "type": "generic",
                    "path": "/pyproject.toml"
                }
            ]
        },
        ".": {
            "release-type": "python",
            "package-name": "selene-sim",
            "component": "selene-sim",
            "draft": false,
            "versioning": "prerelease",
            "prerelease": true,
            "prerelease-type": "alpha",
            "draft-pull-request": true,
            "extra-files": [
                {
                    "type": "toml",
                    "path": "uv.lock",
                    "jsonpath": "$.package[?(@.name.value=='selene-sim')].version"
                },
                {
                    "type": "toml",
                    "path": "Cargo.toml",
                    "jsonpath": "$.workspace.package.version"
                },
                {
                    "type": "toml",
                    "path": "Cargo.lock",
                    "jsonpath": "$.package[?((@.name.value.match(/^selene-/)) && (@.name.value != 'selene-core'))].version"
                }
            ]
        }
    }
}
